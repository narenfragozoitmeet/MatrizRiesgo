# ⚠️ EJEMPLO - NO USAR EN PRODUCCIÓN
# Copiar a .env y configurar valores reales

# Database
MONGO_URL=mongodb://localhost:27017
DB_NAME=riesgo_ia

# CORS - Lista blanca de dominios
CORS_ORIGINS=http://localhost:3000,https://hazard-assess-pro-1.preview.emergentagent.com

# AI/LLM - OBTENER DE: https://app.emergentagent.com/profile
EMERGENT_LLM_KEY=sk-emergent-YOUR-KEY-HERE
LLM_MODEL_PROVIDER=gemini
LLM_MODEL_NAME=gemini-2.5-flash

# Security
MAX_FILE_SIZE_MB=10
RATE_LIMIT_PER_MINUTE=5

# App
APP_NAME=Riesgo IA
VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
